# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Firebase Configuration
# Path to your service account JSON file (e.g., serviceAccountKey.json)
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Firebase Web API Key (Found in Project Settings > General)
# Required for backend-based signup/login
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
